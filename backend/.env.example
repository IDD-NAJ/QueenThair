# QUEENTHAIR Backend API Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# Application
# =============================================================================
NODE_ENV=production
PORT=3000
APP_VERSION=1.0.0
SERVER_ID=queenthair-api-01

# =============================================================================
# JWT Configuration
# =============================================================================
# Generate a secure random string (min 64 characters) for JWT_SECRET
# Example: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secure_random_string_here_min_64_chars_long_for_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# =============================================================================
# Database Configuration
# =============================================================================
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://queenthair_user:your_secure_password@localhost:5432/queenthair
DB_POOL_MIN=2
DB_POOL_MAX=10

# =============================================================================
# Redis Configuration
# =============================================================================
# Used for rate limiting, token blacklisting, caching, and metrics
REDIS_URL=redis://localhost:6379

# =============================================================================
# CORS Configuration
# =============================================================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://queenthair.com,https://www.queenthair.com,http://localhost:3000

# =============================================================================
# Rate Limiting Configuration
# =============================================================================
# Comma-separated list of IPs to whitelist from rate limiting
RATE_LIMIT_WHITELIST=127.0.0.1,10.0.0.1

# =============================================================================
# Email Configuration (Nodemailer)
# =============================================================================
# For SendGrid: SMTP_USER=apikey, SMTP_PASS=your_sendgrid_api_key
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key_here
SMTP_FROM=noreply@queenthair.com
ALERT_EMAIL_TO=admin@queenthair.com,security@queenthair.com

# =============================================================================
# Slack Alerts Configuration
# =============================================================================
# Create an incoming webhook at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# =============================================================================
# Twilio SMS Configuration (for critical alerts)
# =============================================================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM=+15551234567
TWILIO_ALERT_TO=+15559876543

# =============================================================================
# Security Configuration
# =============================================================================
# Bcrypt cost factor (higher = more secure but slower)
BCRYPT_ROUNDS=12

# =============================================================================
# Frontend URL (for password reset links, email confirmations)
# =============================================================================
FRONTEND_URL=https://queenthair.com

# =============================================================================
# Logging Configuration
# =============================================================================
# Log levels: error, warn, info, http, debug
LOG_LEVEL=info

# =============================================================================
# Feature Flags (optional)
# =============================================================================
ENABLE_SMS_ALERTS=true
ENABLE_SLACK_ALERTS=true
ENABLE_EMAIL_ALERTS=true
