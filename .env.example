# ─────────────────────────────────────────────
#  QUEENTHAIR – Environment Variables Template
#  Copy this file to .env and fill in values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────

# ── Supabase ──────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service-role key: SERVER / EDGE FUNCTIONS ONLY. Never expose to browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Stripe ────────────────────────────────────
# Secret key: SERVER / EDGE FUNCTIONS ONLY. Never expose to browser.
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# Publishable key is safe for the browser
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# ── Email (Resend) ────────────────────────────
# https://resend.com – SERVER / EDGE FUNCTIONS ONLY.
RESEND_API_KEY=re_your-resend-api-key

# ── Site Config ───────────────────────────────
VITE_SITE_URL=http://localhost:5173
SITE_URL=http://localhost:5173
SUPPORT_EMAIL=support@Queenthair.com
DEFAULT_FROM_EMAIL=QUEENTHAIR <hello@Queenthair.com>

# ── Analytics (optional) ──────────────────────
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Image APIs (optional) ─────────────────────
# Free stock photo APIs for product images
# Get keys from: unsplash.com/developers, pexels.com/api, pixabay.com/api
VITE_UNSPLASH_ACCESS_KEY=your-unsplash-access-key
VITE_PEXELS_API_KEY=your-pexels-api-key
VITE_PIXABAY_API_KEY=your-pixabay-api-key
